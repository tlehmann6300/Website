# =============================================================================
# IBC Website — Apache configuration
# Performance, security, and routing rules. Loaded by Apache; PHP built-in
# server ignores it (development uses different HTTP layer).
# =============================================================================

# ── HTTPS Enforcement ────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !=https
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Strip trailing index.html
    RewriteCond %{THE_REQUEST} \s/+(.*?)/index\.html[\s?] [NC]
    RewriteRule ^ /%1 [L,R=301]
</IfModule>

# ── Custom error pages ───────────────────────────────────────────────────────
ErrorDocument 403 /403.html
ErrorDocument 404 /404.html
ErrorDocument 500 /500.html

# ── Security Headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Prevent clickjacking — allow iframes only on the same origin
    Header always set X-Frame-Options "SAMEORIGIN"

    # Disable MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Don't leak full URL on outbound requests
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Restrict powerful browser APIs we don't use
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=()"

    # Force HTTPS for 2 years (after you've verified everything works on HTTPS)
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" env=HTTPS

    # Cross-origin policy — same-origin for our resources
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"

    # Content Security Policy — locks down what can load.
    # Includes the few external services this site actually uses:
    #   - Google Analytics (gtag), Google reCAPTCHA, Google Tag Manager
    #   - Microsoft Forms (Infoabend signup link target)
    #   - Instagram embeds (used on fuer-studierende.html iframes)
    Header always set Content-Security-Policy "default-src 'self'; \
        script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://www.google.com https://www.gstatic.com; \
        style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; \
        img-src 'self' data: blob: https: ; \
        font-src 'self' data: https://fonts.gstatic.com; \
        connect-src 'self' https://www.google-analytics.com https://www.googletagmanager.com https://region1.google-analytics.com; \
        frame-src 'self' https://www.google.com https://www.instagram.com https://www.youtube.com https://forms.office.com; \
        media-src 'self' blob:; \
        object-src 'none'; \
        base-uri 'self'; \
        form-action 'self'; \
        frame-ancestors 'self'; \
        upgrade-insecure-requests"

    # Drop the leaky default Apache Server header
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>

# ── Compression ──────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript text/javascript
    AddOutputFilterByType DEFLATE application/json application/xml application/rss+xml application/atom+xml
    AddOutputFilterByType DEFLATE image/svg+xml font/ttf font/otf application/font-woff
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
</IfModule>
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css
    AddOutputFilterByType BROTLI_COMPRESS application/javascript application/x-javascript text/javascript
    AddOutputFilterByType BROTLI_COMPRESS application/json image/svg+xml font/ttf font/otf
</IfModule>

# ── Cache Control ────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault                              "access plus 1 month"

    # HTML — short cache to allow content updates to ship fast
    ExpiresByType text/html                     "access plus 0 seconds"

    # JSON data files — short cache (event config, translations)
    ExpiresByType application/json              "access plus 5 minutes"

    # Long cache for static assets (rely on filename hashing for busting)
    ExpiresByType text/css                      "access plus 1 year"
    ExpiresByType application/javascript        "access plus 1 year"
    ExpiresByType text/javascript               "access plus 1 year"

    # Images
    ExpiresByType image/jpeg                    "access plus 1 year"
    ExpiresByType image/png                     "access plus 1 year"
    ExpiresByType image/webp                    "access plus 1 year"
    ExpiresByType image/avif                    "access plus 1 year"
    ExpiresByType image/svg+xml                 "access plus 1 year"
    ExpiresByType image/gif                     "access plus 1 year"
    ExpiresByType image/x-icon                  "access plus 1 year"

    # Fonts
    ExpiresByType font/woff                     "access plus 1 year"
    ExpiresByType font/woff2                    "access plus 1 year"
    ExpiresByType application/font-woff         "access plus 1 year"
    ExpiresByType application/font-woff2        "access plus 1 year"
    ExpiresByType font/ttf                      "access plus 1 year"
    ExpiresByType font/otf                      "access plus 1 year"
</IfModule>
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|woff|woff2|ttf|otf|jpg|jpeg|png|webp|avif|svg|gif|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </FilesMatch>
    <FilesMatch "\.(json)$">
        Header set Cache-Control "public, max-age=300, must-revalidate"
    </FilesMatch>
</IfModule>

# ── Block sensitive files ────────────────────────────────────────────────────
<FilesMatch "(^\.|composer\.(json|lock)|package(-lock)?\.json|\.env|\.git.*|\.htaccess|\.htpasswd|\.user\.ini|README\.md)$">
    Require all denied
</FilesMatch>

# Block direct access to private/ and vendor/
RedirectMatch 403 ^/private/?
RedirectMatch 403 ^/vendor/?
RedirectMatch 403 ^/old_page/?
RedirectMatch 403 ^/test_codes/?

# ── MIME types ───────────────────────────────────────────────────────────────
<IfModule mod_mime.c>
    AddType image/webp .webp
    AddType image/avif .avif
    AddType font/woff2 .woff2
    AddType application/javascript .mjs
    AddType application/manifest+json .webmanifest
</IfModule>

# ── Disable directory listing ────────────────────────────────────────────────
Options -Indexes -MultiViews
